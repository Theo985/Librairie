-- ============================================
-- SIMPLE GUI (FLUXUS STYLE)
-- ============================================

function Library.CreateGUI()
    local gui = Instance.new("ScreenGui")
    gui.Name = "RivalsLibrary"
    gui.Parent = game:GetService("CoreGui")
    
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 300, 0, 400)
    mainFrame.Position = UDim2.new(0.5, -150, 0.5, -200)
    mainFrame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.15)
    mainFrame.BackgroundTransparency = 0.1
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = gui
    
    -- Title
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
    title.Text = "Rivals Cheat Library"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.GothomBold
    title.TextSize = 18
    title.Parent = mainFrame
    
    -- Make draggable
    local dragging = false
    local dragStart
    local startPos
    
    title.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    
    title.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    -- Toggle buttons
    local yOffset = 40
    local buttons = {
        {"Aimbot", "AimbotEnabled"},
        {"Silent Aim", "SilentAimEnabled"},
        {"Triggerbot", "TriggerbotEnabled"},
        {"ESP", "ESPEnabled"},
        {"Noclip", "NoclipEnabled"},
        {"Fly", "FlyEnabled"},
        {"Speed", "SpeedEnabled"},
    }
    
    for _, btn in pairs(buttons) do
        local button = Instance.new("TextButton")
        button.Size = UDim2.new(0, 120, 0, 30)
        button.Position = UDim2.new(0, 10, 0, yOffset)
        button.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
        button.Text = btn[1] .. " [OFF]"
        button.TextColor3 = Color3.new(1, 1, 1)
        button.Font = Enum.Font.Gothom
        button.TextSize = 14
        button.Parent = mainFrame
        
        local setting = Settings[btn[2]]
        button.MouseButton1Click:Connect(function()
            Settings[btn[2]] = not Settings[btn[2]]
            button.Text = btn[1] .. (Settings[btn[2]] and " [ON]" or " [OFF]")
            
            -- Start/stop features automatically
            if btn[2] == "AimbotEnabled" then
                if Settings.AimbotEnabled then Library.StartAimbot() else Library.StopAimbot() end
            elseif btn[2] == "ESPEnabled" then
                if Settings.ESPEnabled then Library.CreateESP() else Library.RemoveAllESP() end
            elseif btn[2] == "NoclipEnabled" then
                if Settings.NoclipEnabled then Library.StartNoclip() else Library.StopNoclip() end
            elseif btn[2] == "FlyEnabled" then
                if Settings.FlyEnabled then Library.StartFly() else Library.StopFly() end
            elseif btn[2] == "SpeedEnabled" then
                if Settings.SpeedEnabled then Library.SetSpeed(Settings.SpeedValue) else Library.ResetSpeed() end
            end
        end)
        
        yOffset = yOffset + 40
    end
    
    -- Speed slider
    local speedLabel = Instance.new("TextLabel")
    speedLabel.Size = UDim2.new(0, 120, 0, 20)
    speedLabel.Position = UDim2.new(0, 150, 0, 40)
    speedLabel.BackgroundTransparency = 1
    speedLabel.Text = "Speed: " .. Settings.SpeedValue
    speedLabel.TextColor3 = Color3.new(1, 1, 1)
    speedLabel.Font = Enum.Font.Gothom
    speedLabel.TextSize = 12
    speedLabel.Parent = mainFrame
    
    local speedSlider = Instance.new("TextBox")
    speedSlider.Size = UDim2.new(0, 80, 0, 25)
    speedSlider.Position = UDim2.new(0, 150, 0, 60)
    speedSlider.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
    speedSlider.Text = tostring(Settings.SpeedValue)
    speedSlider.TextColor3 = Color3.new(1, 1, 1)
    speedSlider.Font = Enum.Font.Gothom
    speedSlider.TextSize = 14
    speedSlider.Parent = mainFrame
    
    speedSlider.FocusLost:Connect(function()
        local num = tonumber(speedSlider.Text)
        if num then
            Settings.SpeedValue = math.clamp(num, 16, 250)
            speedSlider.Text = tostring(Settings.SpeedValue)
            speedLabel.Text = "Speed: " .. Settings.SpeedValue
            if Settings.SpeedEnabled then
                Library.SetSpeed(Settings.SpeedValue)
            end
        else
            speedSlider.Text = tostring(Settings.SpeedValue)
        end
    end)
end

